# Backend runtime
DATABASE_URL=sqlite:///./janshakti.db
JWT_SECRET_KEY=change-this-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Default bootstrap users
DEFAULT_LEADER_NAME=District Leader
DEFAULT_LEADER_EMAIL=leader@janshakti.ai
DEFAULT_LEADER_PASSWORD=Leader@123
DEFAULT_AUTHORITY_NAME=Ward Authority
DEFAULT_AUTHORITY_EMAIL=authority@janshakti.ai
DEFAULT_AUTHORITY_PASSWORD=Authority@123

# AI config
QWEN_PRIORITY_ENABLED=true
QWEN_PRIORITY_MODEL=Qwen/Qwen2.5-0.5B-Instruct
QWEN_PRIORITY_MAX_NEW_TOKENS=220
QWEN_API_PROVIDER=auto
QWEN_API_URL=https://openrouter.ai/api/v1/chat/completions
QWEN_API_KEY=
QWEN_API_MODEL=qwen/qwen3-4b:free
QWEN_API_TIMEOUT=45
QWEN_API_REFERER=
QWEN_API_TITLE=JanShakti-AI
GEMINI_VISION_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_TIMEOUT=30
WHISPER_MODEL=base
ALLOW_SIMULATED_TRANSCRIPTION=false

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
